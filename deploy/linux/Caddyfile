# DeFiNodeNexus Caddy reverse proxy template
# deploy.sh will replace placeholders:
#   __APP_DOMAIN__ -> public hostname
#   __UPSTREAM__   -> app upstream (default 127.0.0.1:9002)

__APP_DOMAIN__ {
  encode zstd gzip

  header {
    -Server
    X-Frame-Options "SAMEORIGIN"
    X-Content-Type-Options "nosniff"
    Referrer-Policy "strict-origin-when-cross-origin"
  }

  reverse_proxy __UPSTREAM__ {
    health_uri /
    health_interval 30s
    health_timeout 5s
  }

  log {
    output file /var/log/caddy/definodenexus-access.log {
      roll_size 20MiB
      roll_keep 10
      roll_keep_for 720h
    }
    format json
  }
}

# ─────────────────────────────────────────────────────────────────────────────
# DeFiNodeNexus — Production Environment Variables
# Copy to /etc/definode/web.env and /etc/definode/keeper.env, then chmod 600
# ─────────────────────────────────────────────────────────────────────────────

# ── Next.js server port (standalone server uses this) ─────────────────────
PORT=9002
HOSTNAME=0.0.0.0

# ── Blockchain / RPC ──────────────────────────────────────────────────────
# CNC production defaults
CNC_RPC_URL=https://rpc.cncchainpro.com
CNC_CHAIN_ID=50716

# Legacy key kept for script compatibility (keeper/health currently read this key)
SEPOLIA_RPC_URL=https://rpc.cncchainpro.com

# ── Contract Addresses ────────────────────────────────────────────────────
NEXT_PUBLIC_NEXUS_ADDRESS=0x6D862Bc5E9486C89c959905D18760204851f6203
NEXT_PUBLIC_SWAP_ADDRESS=0xcF4a673687B3DDEFDedC10C98fcBf43224488dB9
NEXT_PUBLIC_TOT_ADDRESS=0x0C720a3d1AB25b19c132Ba02C74A5D145d7CcDdA
NEXT_PUBLIC_TOF_ADDRESS=0x7300f4fd7C8d1baBC8220BFf04788E1B7A50e13D
NEXT_PUBLIC_USDT_ADDRESS=0x01EDa43B6f88Fb93D48441758B32d26E501F57e0

# CNC aliases
CNC_TOT_TOKEN_ADDRESS=0x0C720a3d1AB25b19c132Ba02C74A5D145d7CcDdA
CNC_TOF_TOKEN_ADDRESS=0x7300f4fd7C8d1baBC8220BFf04788E1B7A50e13D
CNC_USDT_TOKEN_ADDRESS=0x01EDa43B6f88Fb93D48441758B32d26E501F57e0
CNC_NEXUS_ADDRESS=0x6D862Bc5E9486C89c959905D18760204851f6203
CNC_SWAP_ADDRESS=0xcF4a673687B3DDEFDedC10C98fcBf43224488dB9

# Server-side aliases (used by API routes)
NEXUS_ADDRESS=0x6D862Bc5E9486C89c959905D18760204851f6203
SWAP_ADDRESS=0xcF4a673687B3DDEFDedC10C98fcBf43224488dB9
TOT_TOKEN_ADDRESS=0x0C720a3d1AB25b19c132Ba02C74A5D145d7CcDdA
TOF_TOKEN_ADDRESS=0x7300f4fd7C8d1baBC8220BFf04788E1B7A50e13D
USDT_TOKEN_ADDRESS=0x01EDa43B6f88Fb93D48441758B32d26E501F57e0

# ── Keeper / Scheduler ────────────────────────────────────────────────────
# Private key of the keeper/deployer wallet (used only by keeper.js)
DEPLOYER_PRIVATE_KEY=0xYOUR_PRIVATE_KEY

# Runtime file paths
KEEPER_LOCK_FILE=/var/lock/definode-keeper.lock
KEEPER_STATUS_FILE=/opt/definode/DeFiNodeNexus/runtime/keeper/latest-run.json
HEALTH_REPORT_FILE=/opt/definode/DeFiNodeNexus/runtime/health/latest-health-check.json

# Keeper thresholds
MIN_TOT_RESERVE=10000
MIN_USDT_RESERVE=1000
MAX_DEFLATION_DELAY_HOURS=6

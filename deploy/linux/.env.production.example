# ─────────────────────────────────────────────────────────────────────────────
# DeFiNodeNexus — Production Environment Variables
# Copy to /etc/definode/web.env and /etc/definode/keeper.env, then chmod 600
# ─────────────────────────────────────────────────────────────────────────────

# ── Next.js server port (standalone server uses this) ─────────────────────
PORT=3000
HOSTNAME=0.0.0.0

# ── Blockchain / RPC ──────────────────────────────────────────────────────
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_PROJECT_ID

# ── Contract Addresses ────────────────────────────────────────────────────
NEXT_PUBLIC_NEXUS_ADDRESS=0x2cc1Ebf7185F4810C620e0A7D3300B1e381f3b44
NEXT_PUBLIC_SWAP_ADDRESS=0x018F73b493a0F8D0B8f7F85480Ec8E9c9d852ad6
NEXT_PUBLIC_TOT_ADDRESS=0x46f7729e2158Dd005DC6bdD28FaD457d6f036219
NEXT_PUBLIC_TOF_ADDRESS=0x2d764DF04FE2A086780ab3F1Edfb4b39E44C0c1B
NEXT_PUBLIC_USDT_ADDRESS=0x02ED3072eB83e4E0654d30250102aA58cE977789

# Server-side aliases (used by API routes)
NEXUS_ADDRESS=0x2cc1Ebf7185F4810C620e0A7D3300B1e381f3b44
SWAP_ADDRESS=0x018F73b493a0F8D0B8f7F85480Ec8E9c9d852ad6
TOT_TOKEN_ADDRESS=0x46f7729e2158Dd005DC6bdD28FaD457d6f036219
TOF_TOKEN_ADDRESS=0x2d764DF04FE2A086780ab3F1Edfb4b39E44C0c1B
USDT_TOKEN_ADDRESS=0x02ED3072eB83e4E0654d30250102aA58cE977789

# ── Keeper / Scheduler ────────────────────────────────────────────────────
# Private key of the keeper/deployer wallet (used only by keeper.js)
DEPLOYER_PRIVATE_KEY=0xYOUR_PRIVATE_KEY

# Runtime file paths
KEEPER_LOCK_FILE=/var/lock/definode-keeper.lock
KEEPER_STATUS_FILE=/opt/definode/DeFiNodeNexus/runtime/keeper/latest-run.json
HEALTH_REPORT_FILE=/opt/definode/DeFiNodeNexus/runtime/health/latest-health-check.json

# Keeper thresholds
MIN_TOT_RESERVE=10000
MIN_USDT_RESERVE=1000
MAX_DEFLATION_DELAY_HOURS=6

# ── Alert Channels (optional) ─────────────────────────────────────────────
DISCORD_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

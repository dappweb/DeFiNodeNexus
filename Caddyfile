# Caddy 配置文件 - DeFiNodeNexus
# 用于 t1.test2dapp.xyz 域名

t1.test2dapp.xyz {
    # 反向代理到 Next.js 应用
    reverse_proxy localhost:3001 {
        # 转发必要的头部信息
        header_up X-Forwarded-For {http.request.remote}
        header_up X-Forwarded-Proto {http.request.scheme}
        header_up X-Forwarded-Host {http.request.host}
        
        # WebSocket 支持
        header_up Connection "upgrade"
        header_up Upgrade "websocket"
    }
    
    # 启用 gzip 压缩
    encode gzip
    
    # 设置静态资源缓存头
    header /assets/* Cache-Control "public, max-age=31536000, immutable"
    header /_next/* Cache-Control "public, max-age=31536000, immutable"
    header /images/* Cache-Control "public, max-age=86400"
    header /fonts/* Cache-Control "public, max-age=31536000, immutable"
    
    # 设置安全响应头
    header /* X-Content-Type-Options "nosniff"
    header /* X-Frame-Options "SAMEORIGIN"
    header /* X-XSS-Protection "1; mode=block"
    header /* Referrer-Policy "strict-origin-when-cross-origin"
    
    # 日志配置
    log {
        output file /var/log/caddy/access.log
        format json {
            time_format iso8601
        }
    }
}

# 重定向 HTTP 到 HTTPS（Caddy 自动处理）
# 自动 HTTPS 证书管理（Let's Encrypt）

{
  "name": "nextn",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "check:env:bindings": "node -r ./env_conf.js scripts/check-env-bindings.mjs",
    "check:env:bindings:e2e": "CHECK_ENV_MODE=relaxed node -r ./env_conf.js scripts/check-env-bindings.mjs",
    "vercel:env:pull": "npx vercel env pull .env.local",
    "vercel:env:check": "node scripts/check-vercel-local-parity.mjs",
    "predev": "npm run check:env:bindings",
    "prebuild": "npm run check:env:bindings",
    "pretest:e2e": "npm run check:env:bindings:e2e",
    "dev": "next dev --turbopack -p 9002",
    "dev:vercel": "npm run vercel:env:check && npm run build && next start -p 9002",
    "build": "next build",
    "postbuild": "node -r ./env_conf.js scripts/postbuild-copy.mjs",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:install": "playwright install chromium",
    "test:e2e:ci": "start-server-and-test \"npm run dev\" http://127.0.0.1:9002 \"playwright test\"",
    "test:all": "npm run test && npm run test:e2e",
    "pages:build": "npx @cloudflare/next-on-pages",
    "keeper": "node -r ./env_conf.js scripts/keeper.js",
    "keeper:once": "node -r ./env_conf.js scripts/keeper.js --once",
    "health:daily": "node -r ./env_conf.js scripts/daily-health-check.js",
    "tiers:check": "node -r ./env_conf.js scripts/check-fixed-tiers.js",
    "tokenomics:chapter1:local": "npx hardhat run scripts/chapter1-tokenomics-alignment-local.js",
    "nfta:chapter3:local": "npx hardhat run scripts/chapter3-nfta-alignment-local.js",
    "nftb:chapter5:local": "npx hardhat run scripts/chapter5-nftb-alignment-local.js",
    "referral:team:batch:local": "npx hardhat run scripts/team-referral-rewards-batch-local.js",
    "regression:full:local": "npx hardhat run scripts/full-business-regression-local.js",
    "deploy:cnc": "npx hardhat run scripts/deploy-cnc.js --network cnc",
    "deploy:cnc:v3": "SWAP_CONTRACT_NAME=TOTSwapV3 npx hardhat run scripts/deploy-cnc.js --network cnc",
    "verify:cnc": "npx hardhat run scripts/verify-cnc.js --network cnc",
    "replace:swap:v3:cnc": "npx hardhat run scripts/replace-swap-v3.js --network cnc",
    "upgrade:totswap:v3:cnc": "npx hardhat run scripts/upgrade-totswap-v3.js --network cnc",
    "upgrade:nexus:cnc": "npx hardhat run scripts/upgrade-nexus.js --network cnc",
    "upgrade:nexus:v2:cnc": "npx hardhat run scripts/upgrade-nexus-v2-enumerable-admins.js --network cnc",
    "configure:totswap:v3:cnc": "npx hardhat run scripts/configure-totswap-v3.js --network cnc",
    "create:pair:cnc": "npx hardhat run scripts/create-dex-pair.js --network cnc"
  },
  "dependencies": {
    "@hookform/resolvers": "^4.1.3",
    "@openzeppelin/contracts": "5.0.2",
    "@openzeppelin/contracts-upgradeable": "5.0.2",
    "@radix-ui/react-accordion": "^1.2.3",
    "@radix-ui/react-alert-dialog": "^1.1.6",
    "@radix-ui/react-avatar": "^1.1.3",
    "@radix-ui/react-checkbox": "^1.1.4",
    "@radix-ui/react-collapsible": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.6",
    "@radix-ui/react-dropdown-menu": "^2.1.6",
    "@radix-ui/react-label": "^2.1.2",
    "@radix-ui/react-menubar": "^1.1.6",
    "@radix-ui/react-popover": "^1.1.6",
    "@radix-ui/react-progress": "^1.1.2",
    "@radix-ui/react-radio-group": "^1.2.3",
    "@radix-ui/react-scroll-area": "^1.2.3",
    "@radix-ui/react-select": "^2.1.6",
    "@radix-ui/react-separator": "^1.1.2",
    "@radix-ui/react-slider": "^1.2.3",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.1.3",
    "@radix-ui/react-tabs": "^1.1.3",
    "@radix-ui/react-toast": "^1.2.6",
    "@radix-ui/react-tooltip": "^1.1.8",
    "@rainbow-me/rainbowkit": "^2.2.10",
    "@supabase/supabase-js": "^2.99.3",
    "@tanstack/react-query": "^5.96.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "dotenv": "^17.3.1",
    "embla-carousel-react": "^8.6.0",
    "ethers": "^6.13.5",
    "lucide-react": "^0.475.0",
    "mysql2": "^3.20.0",
    "next": "^15.5.14",
    "next-themes": "^0.4.6",
    "react": "^19.2.1",
    "react-day-picker": "^9.11.3",
    "react-dom": "^19.2.1",
    "react-hook-form": "^7.54.2",
    "recharts": "^2.15.1",
    "tailwind-merge": "^3.0.1",
    "tailwindcss-animate": "^1.0.7",
    "viem": "^2.47.10",
    "wagmi": "^2.9.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@cloudflare/next-on-pages": "^1.13.7",
    "@nomicfoundation/hardhat-ethers": "^3.1.3",
    "@nomicfoundation/hardhat-verify": "^2.1.3",
    "@openzeppelin/hardhat-upgrades": "^3.9.1",
    "@playwright/test": "^1.58.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^19.2.1",
    "@types/react-dom": "^19.2.1",
    "hardhat": "^2.28.6",
    "jsdom": "^29.0.1",
    "msw": "^2.12.14",
    "postcss": "^8",
    "start-server-and-test": "^2.1.5",
    "tailwindcss": "^3.4.1",
    "typescript": "^5",
    "vitest": "^4.1.1"
  }
}

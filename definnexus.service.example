# Systemd 服务配置 - DeFiNodeNexus
# 使用说明：
# 1. 复制此文件到 /etc/systemd/system/definnexus.service
# 2. 运行 sudo systemctl daemon-reload
# 3. 运行 sudo systemctl enable definnexus
# 4. 运行 sudo systemctl start definnexus

[Unit]
Description=DeFiNodeNexus Production Server
Documentation=file:///home/ubuntu/DeFiNodeNexus/DEPLOYMENT-START-HERE.md
After=network.target
Wants=caddy.service

[Service]
Type=simple
User=www-data
Group=www-data

# 工作目录
WorkingDirectory=/opt/repos/DeFiNodeNexus

# 环境变量
Environment="NODE_ENV=production"
Environment="PORT=3001"
Environment="NODE_OPTIONS=--max-old-space-size=2048"

# 启动命令
ExecStart=/home/ubuntu/.nvm/versions/node/v18.20.0/bin/node /opt/repos/DeFiNodeNexus/.next/standalone/server.js

# 重启策略
Restart=always
RestartSec=10
StartLimitInterval=60s
StartLimitBurst=3

# 日志
StandardOutput=journal
StandardError=journal
SyslogIdentifier=definnexus

# 资源限制
LimitNOFILE=65536
LimitNPROC=65536

# 超时
TimeoutStartSec=30
TimeoutStopSec=30

[Install]
WantedBy=multi-user.target

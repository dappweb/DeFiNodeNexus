# Never store mnemonic phrases in this file.
# Use a dedicated test wallet private key with minimal balance.

SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_KEY
DEPLOYER_PRIVATE_KEY=YOUR_PRIVATE_KEY_HERE
TOT_TOKEN_ADDRESS=0x0000000000000000000000000000000000000000
TOF_TOKEN_ADDRESS=0x0000000000000000000000000000000000000000
USDT_TOKEN_ADDRESS=0x0000000000000000000000000000000000000000

# TOT token deploy settings
TOT_NAME=TOT Token
TOT_SYMBOL=TOT
TOT_MAX_SUPPLY=1000000000
TOT_INITIAL_SUPPLY=1000000000
# Optional, default is deployer address
TOT_OWNER_ADDRESS=0x0000000000000000000000000000000000000000

# TOF / USDT test token deploy settings
# Optional, default is deployer address
TOKEN_OWNER_ADDRESS=0x0000000000000000000000000000000000000000
TOF_NAME=TOF Token
TOF_SYMBOL=TOF
TOF_MAX_SUPPLY=1000000000
TOF_INITIAL_SUPPLY=1000000000
USDT_NAME=USDT Test
USDT_SYMBOL=USDT
USDT_MAX_SUPPLY=1000000000
USDT_INITIAL_SUPPLY=1000000000

# TOTSwap deploy settings
NEXUS_ADDRESS=0x0000000000000000000000000000000000000000
SWAP_ADDRESS=0x0000000000000000000000000000000000000000
# Liquidity seed amounts (human-readable, e.g. 60000000 = 6% of 1B)
SWAP_SEED_TOT=60000000
SWAP_SEED_USDT=60000000

# Project fund distribution wallets (optional, defaults to deployer)
ZERO_LINE_WALLET=0x0000000000000000000000000000000000000000
COMMUNITY_WALLET=0x0000000000000000000000000000000000000000
FOUNDATION_WALLET=0x0000000000000000000000000000000000000000
INSTITUTION_WALLET=0x0000000000000000000000000000000000000000

# MySQL (Announcements backend)
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_password
MYSQL_DATABASE=aidapp1a
# Optional: if set, POST /api/admin/announcements requires this token in x-admin-token header
ANNOUNCEMENT_ADMIN_TOKEN=CHANGE_ME

# HTTP data service layer (Edge compatible)
ANNOUNCEMENT_DATA_SERVICE_URL=https://your-data-service.example.com
ANNOUNCEMENT_DATA_SERVICE_TOKEN=

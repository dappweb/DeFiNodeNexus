# Never store mnemonic phrases in this file.
# Use a dedicated test wallet private key with minimal balance.

DEPLOYER_PRIVATE_KEY=YOUR_PRIVATE_KEY_HERE
# Optional: If not set, DEPLOYER_PRIVATE_KEY will be used as owner
OWNER_PRIVATE_KEY=YOUR_OWNER_PRIVATE_KEY_HERE
TOT_TOKEN_ADDRESS=0x0000000000000000000000000000000000000000
TOF_TOKEN_ADDRESS=0x0000000000000000000000000000000000000000
USDT_TOKEN_ADDRESS=0x0000000000000000000000000000000000000000

# TOT token deploy settings
TOT_NAME=TOT Token
TOT_SYMBOL=TOT
TOT_MAX_SUPPLY=1000000000
TOT_INITIAL_SUPPLY=1000000000
# Optional, default is deployer address
TOT_OWNER_ADDRESS=0x0000000000000000000000000000000000000000

# TOF / USDT test token deploy settings
# Optional, default is deployer address
TOKEN_OWNER_ADDRESS=0x0000000000000000000000000000000000000000
TOF_NAME=TOF Token
TOF_SYMBOL=TOF
TOF_MAX_SUPPLY=10000000000
TOF_INITIAL_SUPPLY=0
TOF_PREDICTION_MINTER=0x0000000000000000000000000000000000000000
USDT_NAME=USDT Test
USDT_SYMBOL=USDT
USDT_MAX_SUPPLY=1000000000
USDT_INITIAL_SUPPLY=1000000000

# USDT mint script settings
# Comma-separated values; counts must match one-to-one.
# Example:
# USDT_MINT_RECIPIENTS=0x111...,0x222...,0x333...
# USDT_MINT_AMOUNTS=5000,5000,10000
USDT_MINT_RECIPIENTS=
USDT_MINT_AMOUNTS=

# TOTSwap deploy settings
NEXUS_ADDRESS=0x0000000000000000000000000000000000000000
SWAP_ADDRESS=0x0000000000000000000000000000000000000000
# Liquidity seed amounts (human-readable, e.g. 60000000 = 6% of 1B)
SWAP_SEED_TOT=60000000
SWAP_SEED_USDT=60000000
# Optional: choose TOTSwapV3 during deploy
SWAP_CONTRACT_NAME=TOTSwap
# Optional: configure TOTSwapV3 to use an external DEX router/pair
SWAP_DEX_FACTORY_ADDRESS=0x0000000000000000000000000000000000000000
SWAP_DEX_ROUTER_ADDRESS=0x0000000000000000000000000000000000000000
SWAP_DEX_PAIR_ADDRESS=0x0000000000000000000000000000000000000000
SWAP_ENABLE_EXTERNAL_DEX=false
SWAP_PAUSE_SWAP=false

# ========== CNC Chain Configuration ==========
# RPC and Network
CNC_RPC_URL=https://rpc.cncchainpro.com
CNC_CHAIN_ID=50716

# CNC Chain Token Addresses (pre-deployed)
TOT_TOKEN_ADDRESS=0x0C720a3d1AB25b19c132Ba02C74A5D145d7CcDdA
TOF_TOKEN_ADDRESS=0x7300f4fd7C8d1baBC8220BFf04788E1B7A50e13D
USDT_TOKEN_ADDRESS=0xf54cC0F6CE272125c39C45A8141b84989A8765f4

# CNC Chain Deployed Contracts (fill after deployment)
NEXUS_ADDRESS=0x0000000000000000000000000000000000000000
SWAP_ADDRESS=0x0000000000000000000000000000000000000000

# Public CNC RPC URL for frontend
NEXT_PUBLIC_CNC_RPC_URL=https://rpc.cncchainpro.com

# Prediction platform entry URL (frontend shortcut)
NEXT_PUBLIC_PREDICTION_PLATFORM_URL=https://deepseamonster.netlify.app/

# Frontend contract addresses (must equal deployed addresses above)
# Keep these in .env.local and keep values exactly equal to:
# NEXT_PUBLIC_NEXUS_ADDRESS == NEXUS_ADDRESS
# NEXT_PUBLIC_SWAP_ADDRESS  == SWAP_ADDRESS
# NEXT_PUBLIC_TOT_ADDRESS   == TOT_TOKEN_ADDRESS
# NEXT_PUBLIC_TOF_ADDRESS   == TOF_TOKEN_ADDRESS
# NEXT_PUBLIC_USDT_ADDRESS  == USDT_TOKEN_ADDRESS
NEXT_PUBLIC_NEXUS_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_SWAP_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_TOT_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_TOF_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_USDT_ADDRESS=0x0000000000000000000000000000000000000000

# Project fund distribution wallets (optional, defaults to deployer)
ZERO_LINE_WALLET=0x0000000000000000000000000000000000000000
COMMUNITY_WALLET=0x0000000000000000000000000000000000000000
FOUNDATION_WALLET=0x0000000000000000000000000000000000000000
INSTITUTION_WALLET=0x0000000000000000000000000000000000000000

# MySQL (Announcements backend)
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_password
MYSQL_DATABASE=aidapp1a
# Optional: if set, POST /api/admin/announcements requires this token in x-admin-token header
ANNOUNCEMENT_ADMIN_TOKEN=CHANGE_ME

# HTTP data service layer (Edge compatible)
ANNOUNCEMENT_DATA_SERVICE_URL=https://your-data-service.example.com
ANNOUNCEMENT_DATA_SERVICE_TOKEN=

# Keeper bot (deflation + dividend distribution)
# Secret token to auth /api/keeper calls
KEEPER_SECRET=CHANGE_ME_KEEPER
# Daemon loop interval in ms (default: 600000 = 10 min)
KEEPER_INTERVAL_MS=600000
